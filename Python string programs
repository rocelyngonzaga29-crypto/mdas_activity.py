#1 A program for you to calculate the length of a string.
text = input("Enter a string: ")
print("Length of the string:", len(text))


#2 A program counts the number of characters in a string.
text2 = input("\nEnter another string: ")
count = 0
for char in text2:
    count += 1
print("Number of characters:", count)


#3 Change all occurrences of the first character to '$' except the first char.
text3 = input("\nEnter a string: ")
first = text3[0]
result = first + text3[1:].replace(first, "$")
print("Result:", result)


#4 Swap the first two characters of two strings.
str1 = input("\nEnter first string: ")
str2 = input("Enter second string: ")

new_str1 = str2[:2] + str1[2:]
new_str2 = str1[:2] + str2[2:]

print("Swapped strings:", new_str1 + " " + new_str2)


